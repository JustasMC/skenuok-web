{
  "name": "mano-puslapiu-webas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "analyze": "prisma generate && cross-env ANALYZE=true next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "start:prod": "node ./node_modules/prisma/build/index.js migrate deploy && node ./node_modules/next/dist/bin/next start",
    "db:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:smoke": "tsx --test tests/smoke/**/*.test.ts",
    "test": "npm run test:smoke",
    "db:generate": "prisma generate",
    "db:generate:unlock": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/db-generate-unlock.ps1",
    "postinstall": "node scripts/postinstall-prisma.cjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@next/third-parties": "^16.2.4",
    "@prisma/client": "^6.6.0",
    "canvas-confetti": "^1.9.4",
    "lucide-react": "^1.11.0",
    "next": "^15.3.0",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.2",
    "stripe": "^22.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^15.3.0",
    "prisma": "^6.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
