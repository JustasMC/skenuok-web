# --- Production checklist (Deploy) ---
# 1) Stripe: naudokite *Live* raktus (sk_ live_...), ne test. Dashboard → Webhooks →
#    endpoint https://JŪSŲ_DOMENAS/api/webhooks/stripe, įvykis checkout.session.completed,
#    nukopijuokite *signing secret* į STRIPE_WEBHOOK_SECRET.
# 2) AUTH: AUTH_SECRET (32+ baitų atsitiktinis), AUTH_URL = https://JŪSŲ_DOMENAS
#    (el. laiškuose ir callback URL). SMTP / el. paštas turi būti leidžiamas iš to domeno.
# 3) NEXT_PUBLIC_SITE_URL ir Stripe success/cancel URL turi sutapti su tikru domeno.
# 4) Deploy (Railway): npm run start:prod (migrate + next per node) arba Custom Start Command:
#    node ./node_modules/prisma/build/index.js migrate deploy && node ./node_modules/next/dist/bin/next start
# ---

# Site URL (production) — kanoninis domenas meta / OG / sitemap. Jei tuščia Railway build metu, naudojamas RAILWAY_PUBLIC_DOMAIN.
NEXT_PUBLIC_SITE_URL=https://example.com

# Discord incoming webhook (optional; sends lead notification)
DISCORD_WEBHOOK_URL=

# Telegram Bot API (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alternative: generic HTTPS webhook (POST JSON)
CONTACT_WEBHOOK_URL=

# Database — Prisma schema uses PostgreSQL only. Local: Railway "Public Network" URL from Postgres → Variables.
# Append ?sslmode=require (and optionally &connect_timeout=15) for TLS through rlwy.net proxy.
# Railway web service (production): reference Postgres, e.g. ${{ Postgres.DATABASE_URL }} — prefer internal/private URL when offered.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&connect_timeout=15

# Google PageSpeed Insights API (URL skaneris) — Google Cloud API key with PageSpeed API enabled
PSI_API_KEY=
PAGESPEED_API_KEY=
GOOGLE_PAGESPEED_API_KEY=

# OpenAI — AI rekomendacijos skaneriui, globaliam ChatBot (/api/chat) ir agentui
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# SEO straipsnio generavimas (chat completions max_tokens), numatytai 7000; diapazonas 2000–16000
# OPENAI_ARTICLE_MAX_TOKENS=7000

# SEO agentas (ReAct) — /api/agent/seo-assistant; riboja žingsnius, skenavimus ir apytikslį tokenų biudžetą
# AGENT_MAX_STEPS=6
# AGENT_MAX_TOOL_SCANS=8
# AGENT_MAX_ESTIMATED_TOKENS=18000

# Chat + agent route: kliento nutraukimas + max trukmė (ms). Numatytasis 120000.
# ROUTE_HANDLER_MAX_MS=120000

# Serper (Google Search API) — kursų skaneris: nemokamos YouTube alternatyvos pagal AI temas
SERPER_API_KEY=
# COURSE_SERP_MIN_PRICE_EUR=50
# COURSE_SERP_MAX_QUERIES=3
# COURSE_SERP_ITEMS_PER_TOPIC=2
# Kripto temoms: pirmoji (YouTube) Serper užklausa su gl=us hl=en — daugiau kokybiško angliško turinio (AI vis tiek gali pateikti LT).
# COURSE_SERP_CRYPTO_USE_ENGLISH=true

# Kursų skaneris (/api/course-scan): prieš analizę rezervuojama bazė + Serper papildas; po analizės grąžinamas skirtumas
# COURSE_SCAN_CREDITS_BASE=1
# COURSE_SCAN_CREDITS_SERPER_EXTRA=1

# Stripe (Test: sk_test_... / whsec_...; Live: sk_live_... / whsec_... iš Live webhook)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Checkout: būtinas Stripe Price ID (price_...), ne prod_. Products → kaina → nukopijuokite „Price ID“.
STRIPE_PRICE_ID_20_EUR=
# Pasirinktinai: 5 € planas (jei užpildyta — /pricing rodo du „Užsisakyti“ mygtukus)
# STRIPE_PRICE_ID_5_EUR=
# Kreditai, pridedami po apmokėjimo (metadata; turi atitikti parduodamą paketą)
STRIPE_CREDITS_20_EUR=50
STRIPE_CREDITS_5_EUR=10
# Jei STRIPE_PRICE_ID_20_EUR tuščias, bandomas STRIPE_PRICE_ID (vienas bendras price_)
# STRIPE_PRICE_ID=
# STRIPE_CREDITS_PER_PURCHASE=50
# Po Checkout redirect: pilnas URL (pvz. https://skenuok.com/success) — turi sutapti su Stripe leidžiamais URL.
# Jei tuščia — naudojamas NEXT_PUBLIC_SITE_URL + STRIPE_CHECKOUT_SUCCESS_PATH (/success).
# STRIPE_CHECKOUT_SUCCESS_URL=https://skenuok.com/success
# STRIPE_CHECKOUT_SUCCESS_PATH=/success

# Auth.js v5
AUTH_SECRET=
AUTH_URL=
# Google prisijungimas (OAuth 2.0): Google Cloud Console → APIs & Services → Credentials → OAuth client
# Authorized redirect URI: https://JŪSŲ_DOMENAS/api/auth/callback/google (lokaliai: http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Lokalinis prisijungimas be Google (tik NODE_ENV=development). Production: AUTH_DEV_LOGIN=false
# AUTH_DEV_LOGIN=true
# DEV_LOGIN_EMAIL=dev@local.test
# DEV_LOGIN_PASSWORD=keiskite-į-saugų-slaptažodį
# Pasirinktinai: Magic Link per SMTP (jei užpildyta — rodoma /login puslapyje)
# Taip pat naudojama Stripe „patvirtinimo“ laiškams po kreditų pirkimo (checkout.session.completed).
EMAIL_FROM=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
